# ============================================================
# GoldBridge AI — environment configuration
# Copy to `.env.local` and fill in values.
# ============================================================

# Required: enables /api/score to run the ma-compatibility-scoring pipeline
# automatically (document extraction -> Claude -> deterministic scoring ->
# PDF report) when the user clicks "Organize & Continue" on /analyze.
# Without this set, the route returns a 501 explaining it needs to be
# configured, and the app stays runnable via the manual PDF-upload path on
# the Report page.
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for document extraction.
# Defaults to claude-sonnet-4-5-20250929 if unset.
ANTHROPIC_MODEL=

# ------------------------------------------------------------
# Legacy: an earlier scaffold routed scoring to a separately-hosted agent
# endpoint instead of running in-process. That path is no longer used by
# /api/score (see src/app/api/score/route.ts) — scoring now happens directly
# in this app using ANTHROPIC_API_KEY above. These are kept only in case you
# want to point at an external agent again in the future; unused otherwise.
# ------------------------------------------------------------
MA_SCORING_AGENT_URL=
MA_SCORING_AGENT_KEY=
MA_SCORING_AGENT_NAME=ma-compatibility-scoring
